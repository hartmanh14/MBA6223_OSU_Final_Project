# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/

# Data cache (regenerated at runtime — do not commit stale data)
data/*.json

# Keep the .gitkeep so the data/ directory is tracked
!data/.gitkeep

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Secrets
.env
.env.local
